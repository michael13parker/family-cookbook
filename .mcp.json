{
  "mcpServers": {
    "apple-events": {
      "command": "npx",
      "args": ["-y", "mcp-server-apple-events"]
    },
    "google-docs": {
      "command": "npx",
      "args": ["-y", "@a-bonus/google-docs-mcp"],
      "env": {
        "GOOGLE_CLIENT_ID": "${GOOGLE_CLIENT_ID:-}",
        "GOOGLE_CLIENT_SECRET": "${GOOGLE_CLIENT_SECRET:-}",
        "MCP_TOOL_GROUPS": "docs,drive"
      }
    }
  }
}
